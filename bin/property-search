#!/usr/bin/env bash
# Wrapper so OpenClaw invokes one stable, allowlistable command.
# Runs the property-search CLI from the repo root (where .env + node_modules live).
# $0 is this script's path -> dirname/.. resolves the repo root on any machine.
cd "$(dirname "$0")/.." || exit 1
exec npx tsx skills/propertySearch/search.cli.ts "$@"
